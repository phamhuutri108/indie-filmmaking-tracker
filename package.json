{
  "name": "indie-filmmaking-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/workers/index.ts --port 8787",
    "dev:pages": "cd src/pages && vite",
    "build:pages": "cd src/pages && vite build",
    "deploy": "wrangler deploy src/workers/index.ts",
    "deploy:full": "npm run build:pages && wrangler deploy src/workers/index.ts",
    "db:migrate": "wrangler d1 execute ift-db --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute ift-db --file=src/db/seed.sql",
    "db:migrate:local": "wrangler d1 execute ift-db --local --file=src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute ift-db --local --file=src/db/seed.sql",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "hono": "^4.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^4.69.0"
  }
}
